# vivijure-local-16gb config. Copy to `.env` and fill in. NEVER commit your real .env.

# R2 (the SHARED vivijure bucket): the backend reads the keyframe by key and writes the finished clip
# by key, so the studio's local-gpu module never moves bytes. This is the ONE credential the backend
# holds. Use a per-function R2 key scoped to this bucket (read keyframes/, write clips/). REQUIRED for
# real renders.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vivijure

# Optional S3 endpoint override. BLANK (default) = Cloudflare R2 (the endpoint is derived from your
# R2_ACCOUNT_ID above). Set this to your MinIO / other S3-compatible endpoint for the self-host path
# (e.g. https://minio.local:9000); a custom endpoint automatically switches to path-style addressing,
# which MinIO expects. Leave unset for Cloudflare R2.
R2_S3_ENDPOINT=

# The shared secret the backend REQUIRES on every i2v request (the studio's local-gpu module sends it).
# The tunnel is PUBLIC, so the i2v endpoint refuses to serve without it. Leave BLANK to have the
# container auto-generate a strong one on start (printed in `docker compose logs vivijure-local-16gb`
# -- copy it to the studio). Set it explicitly for a STABLE token across restarts (`openssl rand -hex 32`).
LOCAL_BACKEND_TOKEN=

# Tunnel mode. BLANK (default) = a TryCloudflare QUICK tunnel: zero config, prints a
# https://<random>.trycloudflare.com URL in `docker compose logs cloudflared` -- that URL is your
# LOCAL_BACKEND_URL. For a STABLE named-tunnel hostname, set TUNNEL_TOKEN AND add the small
# docker-compose.override.yml from docs/HOMELABBER.md "A stable address" (it switches cloudflared to
# `tunnel run`, which reads this token).
TUNNEL_TOKEN=

# VRAM cap (GB). The backend pins torch to this fraction of the card BEFORE any model load, so a 16GB
# homelab card cannot silently OOM when PyTorch would otherwise reserve opportunistically on a bigger card.
# 15.5GB is the shipped default: it emulates a real 16GB budget (~0.5GB left for the CUDA context
# outside the fraction). Standard/final 49-frame tiers complete under this cap with model CPU offload
# (proof: docs/proof/RESULTS.md, RTX 4000 Ada 2026-07-15). On a 24GB+ card you may raise this (e.g.
# 20) or set a value >= your card size to use the whole card.
VIVIJURE_MAX_VRAM_GB=15.5

# Optional offload mode. How the render trades speed for VRAM: "none" keeps the whole model resident on
# the GPU (fastest, but needs a >28GB card: the model is ~28GB resident, measured), "model" evicts the
# big text encoder to system RAM after it runs (the consumer-card default on this door), "sequential"
# pages piece-by-piece (slowest, smallest footprint). BLANK (default) = keep each quality tier its own
# safe setting; nothing changes unless you set this. Set VIVIJURE_OFFLOAD=none ONLY on a >28GB card
# (in practice 32GB+, i.e. 48GB-class), where it saves ~17-18s/clip; on 24GB or below it only OOMs, so
# leave it blank. A bad value stops the backend at startup with the valid list. See docs/proof/OFFLOAD-S38.md.
VIVIJURE_OFFLOAD=
