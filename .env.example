# vivijure-local-cogvideox config. Copy to `.env` and fill in. NEVER commit your real .env.

# R2 (the SHARED vivijure bucket): the backend reads the keyframe by key and writes the finished clip
# by key, so the studio's local-gpu module never moves bytes. This is the ONE credential the backend
# holds. Use a per-function R2 key scoped to this bucket (read keyframes/, write clips/). REQUIRED for
# real renders.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vivijure

# The shared secret the backend REQUIRES on every i2v request (the studio's local-gpu module sends it).
# The tunnel is PUBLIC, so the i2v endpoint refuses to serve without it. Leave BLANK to have the
# container auto-generate a strong one on start (printed in `docker compose logs vivijure-local-cogvideox`
# -- copy it to the studio). Set it explicitly for a STABLE token across restarts (`openssl rand -hex 32`).
LOCAL_BACKEND_TOKEN=

# Tunnel mode. BLANK (default) = a TryCloudflare QUICK tunnel: zero config, prints a
# https://<random>.trycloudflare.com URL in `docker compose logs cloudflared` -- that URL is your
# LOCAL_BACKEND_URL. Set TUNNEL_TOKEN (a Cloudflare named-tunnel token) for a STABLE hostname (the
# ongoing/production homelabber setup).
TUNNEL_TOKEN=

# Optional VRAM cap. If you share this GPU with other workloads (a display, another model, a game),
# set the maximum VRAM in GB that vivijure is allowed to claim; the backend pins torch to that fraction
# of the card at startup so it can never grab the whole thing. BLANK (default) = use the whole card.
# Example: VIVIJURE_MAX_VRAM_GB=14 caps vivijure at 14GB and leaves the rest of the card free. A value >= your
# card's size is the same as leaving it blank (full card).
VIVIJURE_MAX_VRAM_GB=
